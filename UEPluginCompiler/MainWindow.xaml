<Window x:Class="UEPluginCompiler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="UE Plugin Compiler"
        MinWidth="860" MinHeight="660"
        Width="980" Height="740"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CaptionHeight="34"
                            CornerRadius="0" ResizeBorderThickness="4"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>   <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- content -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="  UE Plugin Compiler — AzureusBin"
                           Foreground="{StaticResource TextBrush}" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Grid.Column="1" Background="Transparent"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnSettings" Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE713;" ToolTip="Settings"
                            Click="BtnSettings_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="BtnMinimize" Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE921;" ToolTip="Minimize" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE922;" ToolTip="Maximize" Click="BtnMaximize_Click"/>
                    <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="&#xE8BB;" ToolTip="Close" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Title bar divider -->
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{StaticResource WindowBorderBrush}" IsHitTestVisible="False"/>

            <!-- Page container -->
            <ContentControl x:Name="PageHost" Grid.Row="1"/>
        </Grid>
    </Border>
</Window>
