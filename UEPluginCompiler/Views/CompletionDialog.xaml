<Window x:Class="UEPluginCompiler.Views.CompletionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="BuildFlow Complete"
        Width="500" Height="250"
        MinWidth="360" MinHeight="200"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CaptionHeight="34"
                            CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_Drag">
                <TextBlock Text="  BuildFlow Complete" Foreground="{StaticResource TextBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                           shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <!-- Title bar divider -->
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{StaticResource WindowBorderBrush}" IsHitTestVisible="False"/>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock x:Name="txtMessage" Foreground="{StaticResource TextBrush}"
                               FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtPath" Foreground="{StaticResource DimTextBrush}"
                               FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Open Output Folder" Click="BtnOpen_Click"
                            MinWidth="220" Padding="14,6" Margin="0,0,8,0"/>
                    <Button Content="Close" Style="{StaticResource SecondaryButtonStyle}"
                            Width="80" Click="BtnClose_Click" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
