<UserControl x:Class="UEPluginCompiler.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UEPluginCompiler.ViewModels"
             Background="{StaticResource BgBrush}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="UE Plugin Compiler"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Build &amp; Package UE Plugins"
                       FontSize="14"
                       Foreground="{StaticResource DimTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <!-- Buttons -->
            <Button Content="+ New BuildFlow"
                    Command="{Binding NewFlowCommand}"
                    Width="240" Height="40"
                    FontSize="14" FontWeight="SemiBold"
                    Margin="0,0,0,10"/>
            <Button Content="Open BuildFlow..."
                    Command="{Binding OpenFlowCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="240" Height="40"
                    FontSize="14"
                    Margin="0,0,0,32"/>

            <!-- Recent list -->
            <Separator Width="240" Margin="0,0,0,12"/>
            <TextBlock Text="Recent"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource DimTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <!-- Has recent items -->
            <ItemsControl ItemsSource="{Binding RecentFlows}"
                          Visibility="{Binding HasRecent, Converter={StaticResource BoolToVisConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Width="300" Height="36"
                                FontSize="13"
                                Margin="0,0,0,4"
                                Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C4;  " Foreground="{StaticResource DimTextBrush}"/>
                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="  " Foreground="{StaticResource DimTextBrush}"/>
                                <TextBlock Text="{Binding TimeAgo}" Foreground="{StaticResource DimTextBrush}"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <TextBlock Text="No recent BuildFlows."
                       FontSize="13"
                       Foreground="{StaticResource DimTextBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding HasRecent, Converter={StaticResource InvertBoolToVis}}"/>
        </StackPanel>
    </Grid>
</UserControl>
